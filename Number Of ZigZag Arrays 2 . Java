class Solution {
    public int zigZagArrays(int n, int l, int r) {
        int MOD = 1_000_000_007;
        int m = r - l + 1;

        long[][][] dp = new long[n + 1][m][2];

        for (int j = 0; j < m; j++) {
            dp[1][j][0] = 1;
            dp[1][j][1] = 1;
        }

        for (int i = 2; i <= n; i++) {
            for (int j = 0; j < m; j++) {
                for (int k = 0; k < m; k++) {
                    if (j == k) continue;

                    if (j > k) {
                        dp[i][j][1] = (dp[i][j][1] + dp[i - 1][k][0]) % MOD;
                    } else {
                        dp[i][j][0] = (dp[i][j][0] + dp[i - 1][k][1]) % MOD;
                    }
                }
            }
        }
        
        long ans = 0;
        for (int j = 0; j < m; j++) {
            ans = (ans + dp[n][j][0] + dp[n][j][1]) % MOD;
        }

        return (int) ans;
    }
}
